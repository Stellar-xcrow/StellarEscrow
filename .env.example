# StellarEscrow — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env files.

# ── Stellar Network ──────────────────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=

# ── Indexer env var overrides (STELLAR_ESCROW__<SECTION>__<KEY>) ─────────────
# These are validated at indexer startup — the service will exit with a clear
# error message if any required variable is missing or invalid.
STELLAR_ESCROW__STELLAR__NETWORK=testnet
STELLAR_ESCROW__STELLAR__HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_ESCROW__STELLAR__CONTRACT_ID=          # Required: deployed contract ID (C...)
STELLAR_ESCROW__DATABASE__URL=                 # Required: same as DATABASE_URL below
STELLAR_ESCROW__AUTH__API_KEYS=                # Required: comma-separated API keys

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/stellar_escrow

# ── API Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Auth ─────────────────────────────────────────────────────────────────────
API_KEYS=demo-key-123,client-key-456
ADMIN_KEYS=admin-key-123

# ── API Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
INDEXER_URL=http://indexer:3000
# JWT_SECRET=                    # Optional: enable JWT Bearer token auth
# GATEWAY_INSTANCES=             # Optional: name:url:prefix,... for extra upstreams
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ── API Client (TypeScript client overrides) ──────────────────────────────────
STELLAR_ESCROW_API_BASE_URL=http://localhost:3000/api
STELLAR_ESCROW_WS_URL=ws://localhost:3000/api/ws
STELLAR_ESCROW_TIMEOUT_MS=30000
STELLAR_ESCROW_RETRY_MAX=3
STELLAR_ESCROW_RETRY_DELAY_MS=1000
STELLAR_ESCROW_MOCK=false

# ── Optional ─────────────────────────────────────────────────────────────────
REDIS_URL=
LOG_LEVEL=debug

# ── Monitoring & Alerting ─────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=
GRAFANA_URL=http://localhost:3002
ALERT_WEBHOOK_URL=http://indexer:3000/monitoring/alerts
INCIDENT_WEBHOOK_URL=http://indexer:3000/monitoring/alerts
PAGERDUTY_ROUTING_KEY=
ONCALL_EMAIL=oncall@stellarescrow.app
SMTP_HOST=localhost:587
SMTP_FROM=alerts@stellarescrow.app
SMTP_USER=
SMTP_PASSWORD=
